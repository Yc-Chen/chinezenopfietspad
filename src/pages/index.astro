---
import Base from '../layouts/Base.astro';
import Board from '../components/Board.astro';
import LegendPanel from '../components/LegendPanel.astro';
import { getTiles } from '../lib/tiles';
import { getI18n } from '../lib/i18n';

const lang = 'en' as const;
const t = getI18n(lang);
const tiles = getTiles(lang);
---
<Base title={t.game_title} lang={lang} description={t.game_subtitle}>
  <div class="gb">
    <header class="gb__header">
      <p class="gb__edition">{t.game_edition}</p>
      <h1 class="gb__title">{t.game_title}</h1>
      <p class="gb__subtitle">{t.game_subtitle}</p>
    </header>

    <div class="gb__layout">
      <Board tiles={tiles} boardLabel={t.board_label} tileWord={t.tile_word} />

      <aside class="gb__sidebar">
        <LegendPanel t={t} />
        <section id="tile-content" class="gb__panel gb__content" aria-live="polite">
          <p class="gb__hint">{t.hint_start}</p>
        </section>
      </aside>
    </div>
  </div>
</Base>
